<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Public Entertainment Archive</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;700&display=swap" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            user-select: none;
            -webkit-user-select: none;
        }

        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #050505;
            font-family: 'Pixelify Sans', monospace;
            color: #ffffff;
            overflow: hidden;
            cursor: none; /* Hides system cursor */
            perspective: 1000px; /* Enables 3D space for the tilt effect */
        }

        /* --- CRT Effects Layers --- */
        /* Subtle screen flicker */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0; left: 0; bottom: 0; right: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.12) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
            z-index: 999;
            background-size: 100% 4px, 6px 100%;
            pointer-events: none;
        }

        /* Dark edge vignette */
        .crt-vignette {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            box-shadow: inset 0 0 120px rgba(0, 0, 0, 0.85);
            z-index: 998;
            pointer-events: none;
        }

        /* Hardware phosphor emulation animation */
        @keyframes crt-flicker {
            0% { opacity: 0.99; }
            50% { opacity: 1; }
            100% { opacity: 0.985; }
        }
        
        .crt-flicker-layer {
            position: fixed;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.002);
            z-index: 997;
            pointer-events: none;
            animation: crt-flicker 0.2s infinite;
        }

        /* Background Particle Canvas */
        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
        }

        /* Top Status Bar Controls */
        .UI-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 2;
            padding: 24px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            pointer-events: none; 
        }

        .top-row {
            display: flex;
            justify-content: space-between;
            width: 100%;
        }

        .status-box {
            border: 2px solid #ffffff;
            border-radius: 8px;
            padding: 8px 16px;
            font-size: 1rem;
            background-color: rgba(0, 0, 0, 0.6);
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Main Screen Interactive Text Container */
        .main-screen {
            position: absolute;
            top: 50%;
            left: 50%;
            /* Preserves centering anchor while injecting 3D rotation via JavaScript */
            transform: translate(-50%, -50%) rotateX(0deg) rotateY(0deg);
            transform-style: preserve-3d;
            text-align: center;
            z-index: 2;
            pointer-events: none;
            /* Smooths out transition steps as the mouse moves */
            transition: transform 0.15s ease-out;
        }

        .main-title {
            font-size: 4.5rem;
            font-weight: 700;
            margin: 0 0 8px 0;
            letter-spacing: 4px;
            text-shadow: 0 0 12px rgba(255, 255, 255, 0.4);
        }

        .sub-title {
            font-size: 1.2rem;
            font-weight: 400;
            margin: 0;
            opacity: 0.6;
            letter-spacing: 2px;
        }

        /* Custom Retro Cursor */
        #custom-cursor {
            width: 22px;
            height: 22px;
            border: 2px solid #ffffff;
            border-radius: 50%;
            position: fixed;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 10000; /* Stays unconditionally on top of CRT layers */
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #custom-cursor::after {
            content: '';
            width: 4px;
            height: 4px;
            background-color: #ffffff;
            border-radius: 50%;
        }

        .fullscreen-hint {
            position: absolute;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.8rem;
            opacity: 0.3;
            letter-spacing: 1px;
            text-align: center;
        }
    </style>
</head>
<body>

    <div class="crt-vignette"></div>
    <div class="crt-flicker-layer"></div>

    <canvas id="particleCanvas"></canvas>

    <div class="UI-layer">
        <div class="top-row">
            <div class="status-box" id="battery-display">BATTERY: --%</div>
            <div class="status-box" id="datetime-display">00:00:00 | 00/00/00</div>
        </div>
        <div class="fullscreen-hint">CLICK ANYWHERE FOR FULLSCREEN</div>
    </div>

    <div class="main-screen" id="tiltContainer">
        <h1 class="main-title">Public Entertainment Archive</h1>
        <p class="sub-title">Version 1.0.0</p>
    </div>

    <div id="custom-cursor"></div>

    <script>
        const cursor = document.getElementById('custom-cursor');
        const tiltContainer = document.getElementById('tiltContainer');
        
        // --- Cursor Tracking & 3D Parallax Tilt Logic ---
        window.addEventListener('mousemove', (e) => {
            // Move custom cursor
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';

            // Calculate center points of viewport
            const centerX = window.innerWidth / 2;
            const centerY = window.innerHeight / 2;

            // Determine mouse offset vectors from screen center
            const offsetX = e.clientX - centerX;
            const offsetY = e.clientY - centerY;

            // Normalized values (-1 to 1)
            const normalizedX = offsetX / centerX;
            const normalizedY = offsetY / centerY;

            // Configuration for constraints (Keep rotation limited to maintain legibility)
            const maxTiltAngle = 14; 

            // Calculate individual degree limits
            // Moving mouse Right (positive X) tilts Y-axis forward/clockwise
            // Moving mouse Down (positive Y) tilts X-axis away/backwards
            const tiltY = normalizedX * maxTiltAngle;
            const tiltX = -(normalizedY * maxTiltAngle);

            // Dynamically inject structural rotation into element style rules
            tiltContainer.style.transform = `translate(-50%, -50%) rotateX(${tiltX}deg) rotateY(${tiltY}deg)`;
        });

        // Toggle custom cursor visibility based on browser environment focus
        document.addEventListener('mouseleave', () => { cursor.style.opacity = '0'; });
        document.addEventListener('mouseenter', () => { cursor.style.opacity = '1'; });


        // --- Canvas Floating Square Particles ---
        const canvas = document.getElementById('particleCanvas');
        const ctx = canvas.getContext('2d');

        let particles = [];
        const maxParticles = 55;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor() {
                this.reset();
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
            }

            reset() {
                this.size = Math.random() * 3 + 2; // Pixel sizing ranges 2px to 5px
                this.x = Math.random() * canvas.width;
                this.y = canvas.height + this.size; 
                this.speedX = (Math.random() - 0.5) * 0.15; // Slow drifting horizontal vectors
                this.speedY = -(Math.random() * 0.2 + 0.1); // Slow upward vector
                this.opacity = Math.random() * 0.4 + 0.3; 
            }

            update() {
                this.x += this.speedX;
                this.y += this.speedY;

                if (this.y < -this.size || this.x < -this.size || this.x > canvas.width + this.size) {
                    this.reset();
                }
            }

            draw() {
                ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
                ctx.fillRect(this.x, this.y, this.size, this.size); // Forces true square outputs
            }
        }

        for (let i = 0; i < maxParticles; i++) {
            particles.push(new Particle());
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }
        animate();


        // --- Time & Date Module (Top Right) ---
        function updateDateTime() {
            const now = new Date();
            const timeStr = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
            const dateStr = now.toLocaleDateString([], { month: '2-digit', day: '2-digit', year: 'numeric' });
            document.getElementById('datetime-display').innerText = `${timeStr} | ${dateStr}`;
        }
        setInterval(updateDateTime, 1000);
        updateDateTime();


        // --- Battery API Module (Top Left) ---
        function initBattery() {
            const batteryDisplay = document.getElementById('battery-display');

            if ('getBattery' in navigator) {
                navigator.getBattery().then(battery => {
                    function updateBatteryStatus() {
                        const level = Math.floor(battery.level * 100);
                        batteryDisplay.innerText = `BATTERY: ${level}%`;
                    }
                    updateBatteryStatus();
                    battery.addEventListener('levelchange', updateBatteryStatus);
                });
            } else {
                batteryDisplay.innerText = "BATTERY: 100%";
            }
        }
        initBattery();


        // --- Native Fullscreen Trigger ---
        document.body.addEventListener('click', () => {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(err => {
                    console.log(`Fullscreen error setup exception: ${err.message}`);
                });
            }
        });
    </script>
</body>
</html>
